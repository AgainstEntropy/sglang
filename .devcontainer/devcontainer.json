{
    "name": "sglang",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "remoteUser": "devuser",
    "customizations": {
        "vscode": {
            "extensions": [
                // Python development
                "ms-python.python",
                "charliermarsh.ruff",
                // Rust development
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml",
                // My extensions
                "anthropic.claude-code",
                "donjayamanne.githistory",
                "waderyan.gitblame",
                "shd101wyy.markdown-preview-enhanced",
                "ms-toolsai.jupyter"
            ]
        }
    },
    "forwardPorts": [],
    "runArgs": [
        "--gpus",
        "all",
        "--name",
        "yihao-sglang-dev"
    ],
    "mounts": [
        "source=${localEnv:HOME}/.cache/huggingface,target=/home/devuser/.cache/huggingface,type=bind",
        "source=/data/shared_data/models,target=/data/shared_data/models,type=bind,readonly"
    ],
    "postCreateCommand": "sudo chown devuser:devuser /home/devuser/.cache && git config --global user.name 'Yihao Wang' && git config --global user.email '42559837+AgainstEntropy@users.noreply.github.com'",
    // The two lines below ensures that your local changes in the sglang
    // repo is automatically synced to the sglang pip package installed
    // in the dev docker container. You can remove / comment out these
    // two lines if you prefer to sync code changes manually.
    "workspaceMount": "source=${localWorkspaceFolder},target=/sgl-workspace/sglang,type=bind",
    "workspaceFolder": "/sgl-workspace/sglang"
}
